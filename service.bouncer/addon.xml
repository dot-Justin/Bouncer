<?xml version="1.0" encoding="UTF-8"?>
<addon id="service.bouncer"
       name="Bouncer"
       version="1.0.0"
       provider-name="dotJustin">

  <requires>
    <import addon="xbmc.python" version="3.0.0"/>
  </requires>

  <!-- Service entry point: starts at login so it is running before any playback -->
  <extension point="xbmc.service" library="service.py" start="login"/>

  <extension point="xbmc.addon.metadata">
    <summary lang="en_GB">Rating-based playback control for Kodi</summary>
    <platform>all</platform>
  </extension>

</addon>
